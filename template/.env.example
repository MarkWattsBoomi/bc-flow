# Boomi Flow API Credentials
# Generate your API key: Flow platform → Settings → API Keys
FLOW_API_KEY=your_api_key_here

# Tenant ID (the GUID shown in your Flow platform URL or tenant settings)
FLOW_TENANT_ID=your_tenant_id_here

# Base URL (default is the Boomi cloud; change for regional/private deployments)
FLOW_BASE_URL=https://flow.boomi.com

# Set to false to disable SSL verification (e.g. behind a corporate proxy)
FLOW_VERIFY_SSL=true
